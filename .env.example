# ─── App ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ENVIRONMENT=development

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://musicapp:musicapp@localhost:5432/musicapp

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Storage (MinIO locally, Cloudflare R2 in production) ─
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=musicapp
# For R2 in production, set:
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=<r2-access-key>
# S3_SECRET_ACCESS_KEY=<r2-secret-key>

# ─── AI APIs ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Scraping (Apify) ───────────────────────────────────
# Get your API token at https://console.apify.com/settings/integrations
APIFY_API_TOKEN=apify_api_...

# ─── Artist Info ────────────────────────────────────────
ARTIST_NAME=Your Artist Name

# ─── TikTok ─────────────────────────────────────────────
# Register at https://developers.tiktok.com → create an app → get client_key + client_secret
# Add redirect URI: http://localhost:8000/tiktok/callback (dev) or your prod domain
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-railway-domain.up.railway.app/tiktok/callback

# ─── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
